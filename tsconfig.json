{
  "compilerOptions": {
    "target": "ES2020",
    "moduleResolution": "bundler",
    "module": "ESNext",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "types": ["jest"],
    "rootDir": "src",
    "outDir": "dist",
    "ignoreDeprecations": "6.0",
    "declaration": true,
    "emitDeclarationOnly": true
  },
  "include": ["src"],
  "exclude": ["examples", "test", "dist"]
}
