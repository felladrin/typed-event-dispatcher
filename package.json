{
  "name": "typed-event-dispatcher",
  "version": "1.11.6",
  "description": "Strongly-typed events that can be publicly listened but internally-only dispatched.",
  "source": "./src/typed-event-dispatcher.ts",
  "types": "./dist/typed-event-dispatcher.d.ts",
  "main": "./dist/typed-event-dispatcher.js",
  "module": "./dist/typed-event-dispatcher.mjs",
  "unpkg": "./dist/typed-event-dispatcher.global.js",
  "exports": {
    "browser": "./dist/typed-event-dispatcher.mjs",
    "umd": "./dist/typed-event-dispatcher.global.js",
    "import": "./dist/typed-event-dispatcher.mjs",
    "require": "./dist/typed-event-dispatcher.js",
    "default": "./dist/typed-event-dispatcher.mjs"
  },
  "files": [
    "dist",
    "readme-too.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/typed-event-dispatcher.ts --format cjs,esm,iife --global-name typedEventDispatcher --clean --dts",
    "test": "jest --collectCoverage",
    "format": "prettier --write \"**/*.{ts,json,md,yml}\" --ignore-path \".eslintignore\"",
    "docs": "typedoc src/typed-event-dispatcher.ts",
    "prepare": "husky && npm run build",
    "preview-package-contents": "package-check && npm pack --dry-run"
  },
  "keywords": [
    "event",
    "events",
    "dispatcher",
    "emitter",
    "listener",
    "listeners",
    "event-emitter",
    "subscribe"
  ],
  "homepage": "https://felladrin.github.io/typed-event-dispatcher/index.html",
  "repository": "github:felladrin/typed-event-dispatcher",
  "author": {
    "name": "Victor Nogueira",
    "email": "victor@victornogueira.app",
    "url": "https://victornogueira.app"
  },
  "license": "MIT",
  "devDependencies": {
    "@skypack/package-check": "0.2.2",
    "@types/jest": "30.0.0",
    "husky": "9.1.7",
    "jest": "30.3.0",
    "prettier": "3.8.2",
    "ts-jest": "29.4.9",
    "tsup": "8.5.1",
    "typedoc": "0.28.18",
    "typescript": "6.0.2"
  }
}
